# AWS Configuration
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default                        # or use AWS_ACCESS_KEY_ID / SECRET

# GRC Platform Configuration
GRC_ENVIRONMENT=dev                        # dev | staging | prod
GRC_STACK_NAME=grc-evidence-platform

# S3 Buckets (populated by setup.py or CF outputs)
GRC_EVIDENCE_BUCKET=                       # auto-populated after deploy
GRC_CLOUDTRAIL_BUCKET=                     # auto-populated after deploy
GRC_REPORTS_BUCKET=                        # auto-populated after deploy

# DynamoDB Tables (populated by setup.py or CF outputs)
GRC_METADATA_TABLE=GRC-Evidence-Metadata
GRC_REMEDIATION_TABLE=GRC-Remediation-Log
GRC_SCORECARD_TABLE=GRC-Scorecards

# SNS
GRC_ALERT_TOPIC_ARN=                       # auto-populated after deploy
GRC_ALERT_EMAIL=                           # your email for HIGH/CRITICAL alerts

# Lambda
GRC_EVIDENCE_PROCESSOR_ARN=               # auto-populated after deploy
GRC_REMEDIATION_ENGINE_ARN=               # auto-populated after deploy

# AI Configuration
ENABLE_AI_ANALYSIS=true                    # true | false
BEDROCK_REGION=us-east-1                   # Nemotron Nano 12B v2
BEDROCK_MODEL_ID=nvidia.nemotron-nano-12b-v2

# Remediation Configuration
REMEDIATION_MODE=APPROVAL_REQUIRED        # DRY_RUN | AUTO | APPROVAL_REQUIRED
                                        # DRY_RUN: Test only, logs but doesn't execute
                                        # AUTO: Execute immediately without approval (CAUTION!)
                                        # APPROVAL_REQUIRED: Requires manual approval before execution
                                        # WARNING: AUTO mode will automatically remediate violations

# Evidence Retention
EVIDENCE_RETENTION_DAYS=90                 # TTL for DynamoDB records
EVIDENCE_GLACIER_DAYS=90                   # S3 lifecycle: move to Glacier after N days

# Reporting
REPORT_SCHEDULE=weekly                     # daily | weekly | monthly
SCORECARD_SCHEDULE=daily
AUDIT_PERIOD_DAYS=30                       # Default reporting period

# Feature Flags
ENABLE_MACIE=true
ENABLE_INSPECTOR=true
ENABLE_GUARDDUTY_RDS=true
ENABLE_CI_CD_GATE=true
